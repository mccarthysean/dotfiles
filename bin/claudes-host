#!/usr/bin/env bash
# claudes — Smart DevPod + tmux session manager for Claude Code
#
# Usage:
#   claudes                  # Auto-detect workspace from PWD, or show menu
#   claudes WORKSPACE        # Connect to workspace's default tmux session
#   claudes WORKSPACE LABEL  # Connect/create WORKSPACE-LABEL tmux session
#   claudes --local [NAME]   # Local tmux session in current dir (no DevPod)
#   claudes --list           # Show all workspaces + sessions
#   claudes --help           # Show this help
#
# From WSL in ~/git_wsl/rcom:  claudes → auto-detects rcom → SSH → tmux + Claude
# From phone via Termius:       claudes → interactive menu of sessions + workspaces
#
# Backwards compatible: claude-session symlink still works.

set -euo pipefail

# ─── Constants ───

DEVPOD_WS_DIR="$HOME/.devpod/contexts/default/workspaces"
SSH_TIMEOUT=10
RENAME_PROMPT="Look at this terminal session scrollback. Reply with ONLY two lowercase words separated by a hyphen (no punctuation, no explanation) describing the most specific task or feature this session worked on. NEVER reply with generic words like misc, task, work, code, session, or general. Instead, identify the actual subject matter — a feature name, bug target, file type, or domain topic. Examples: fix-logout, soil-pricing, traefik-certs, add-charts, test-mqtt, schema-migration"

# ─── Helpers ───

sanitize_name() {
    echo "$1" | head -1 | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9-'
}

# Open a tmux session safely (handles nesting when already inside tmux)
# Usage: tmux_safe_open "session_name" "/working/dir" [--attach-only]
tmux_safe_open() {
    local session="$1" dir="$2" attach_only="${3:-}"
    if [ -n "${TMUX:-}" ]; then
        if [ "$attach_only" != "--attach-only" ]; then
            tmux new-session -d -s "$session" -c "$dir" 2>/dev/null || true
        fi
        exec tmux switch-client -t "$session"
    else
        if [ "$attach_only" = "--attach-only" ]; then
            exec tmux attach-session -t "$session"
        else
            exec tmux new-session -A -s "$session" -c "$dir"
        fi
    fi
}

# ─── Associative arrays for workspace data ───

declare -A DIR_TO_WS    # /home/sean/git_wsl/rcom → rcom
declare -A WS_UID       # rcom → default-rc-4f00c
declare -A WS_DIR       # rcom → /home/sean/git_wsl/rcom
declare -a WS_LIST=()   # ordered list of workspace names

# ─── Workspace Discovery ───

discover_workspaces() {
    [ -d "$DEVPOD_WS_DIR" ] || return 0

    for ws_dir in "$DEVPOD_WS_DIR"/*/; do
        local json="$ws_dir/workspace.json"
        [ -f "$json" ] || continue

        # Parse JSON without jq — extract id, uid, localFolder using grep+sed
        local id uid folder
        id=$(grep -o '"id":"[^"]*"' "$json" | head -1 | sed 's/"id":"//;s/"//')
        uid=$(grep -o '"uid":"[^"]*"' "$json" | head -1 | sed 's/"uid":"//;s/"//')
        folder=$(grep -o '"localFolder":"[^"]*"' "$json" | head -1 | sed 's/"localFolder":"//;s/"//')

        [ -n "$id" ] || continue

        WS_LIST+=("$id")
        WS_UID["$id"]="$uid"
        if [ -n "$folder" ]; then
            WS_DIR["$id"]="$folder"
            DIR_TO_WS["$folder"]="$id"
        fi
    done
}

# ─── Detect Running Workspaces ───

declare -A WS_RUNNING  # rcom → 1

detect_running() {
    local containers
    containers=$(docker ps --format "{{.Names}}" 2>/dev/null || true)
    [ -n "$containers" ] || return 0

    for ws in "${WS_LIST[@]}"; do
        local uid="${WS_UID[$ws]:-}"
        [ -n "$uid" ] || continue
        if echo "$containers" | grep -q "^${uid}-"; then
            WS_RUNNING["$ws"]=1
        fi
    done
}

# ─── PWD Auto-Detection ───
# Walk up from $PWD checking each directory against DIR_TO_WS

detect_workspace_from_pwd() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -n "${DIR_TO_WS[$dir]:-}" ]; then
            echo "${DIR_TO_WS[$dir]}"
            return 0
        fi
        dir=$(dirname "$dir")
    done
    return 1
}

# ─── Remote Tmux Session Probing ───

declare -a LOCAL_SESSIONS=()    # local tmux sessions on WSL host
declare -A LOCAL_SESSION_DIR=() # session → pane working directory
declare -A LOCAL_SESSION_ATT=() # session → attached client count (0 = detached)
declare -A LOCAL_SESSION_TTL=() # session → pane title (e.g. "✳ Claude Code")

detect_local_sessions() {
    local sessions
    sessions=$(tmux list-sessions -F '#{session_name}|#{session_attached}' 2>/dev/null || true)
    [ -n "$sessions" ] || return 0
    while IFS='|' read -r name attached; do
        LOCAL_SESSIONS+=("$name")
        LOCAL_SESSION_ATT["$name"]="$attached"
    done <<< "$sessions"

    # Get active pane's working directory and title per session
    local panes
    panes=$(tmux list-windows -a -F '#{session_name}|#{window_active}|#{pane_current_path}|#{pane_title}' 2>/dev/null || true)
    [ -n "$panes" ] || return 0
    while IFS='|' read -r name active path title; do
        [ "$active" = "1" ] || continue
        LOCAL_SESSION_DIR["$name"]="$path"
        LOCAL_SESSION_TTL["$name"]="$title"
    done <<< "$panes"
}

declare -A WS_SESSIONS  # rcom → "rcom,rcom-frontend"

probe_remote_sessions() {
    local pids=()
    local tmpdir
    tmpdir=$(mktemp -d)

    for ws in "${WS_LIST[@]}"; do
        [ "${WS_RUNNING[$ws]:-}" = "1" ] || continue
        (
            ssh -o ConnectTimeout="$SSH_TIMEOUT" -o BatchMode=yes \
                "${ws}.devpod" \
                "tmux list-sessions -F '#{session_name}' 2>/dev/null || true" \
                > "$tmpdir/$ws" 2>/dev/null || true
        ) &
        pids+=($!)
    done

    # Wait for all SSH probes
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Read results
    for ws in "${WS_LIST[@]}"; do
        [ -f "$tmpdir/$ws" ] || continue
        local sessions
        sessions=$(cat "$tmpdir/$ws")
        if [ -n "$sessions" ]; then
            WS_SESSIONS["$ws"]=$(echo "$sessions" | tr '\n' ',' | sed 's/,$//')
        fi
    done

    rm -rf "$tmpdir"
}

# ─── Session Name Helper ───

suggest_next_name() {
    local base="$1"
    local sessions="$2"  # comma-separated list of existing sessions
    if ! echo ",$sessions," | grep -q ",$base,"; then
        echo "$base"
        return
    fi
    local i=2
    while echo ",$sessions," | grep -q ",${base}-${i},"; do
        i=$((i + 1))
    done
    echo "${base}-${i}"
}

# ─── Show Help ───

show_help() {
    sed -n '2,14s/^# //p' "$0"
}

# ─── Show List ───

show_list() {
    echo ""
    echo "  DevPod Workspaces"
    echo "  ═════════════════"
    echo ""

    if [ ${#WS_LIST[@]} -eq 0 ]; then
        echo "  No workspaces found."
        echo ""
        return
    fi

    # Running
    local has_running=0
    for ws in "${WS_LIST[@]}"; do
        if [ "${WS_RUNNING[$ws]:-}" = "1" ]; then
            if [ "$has_running" -eq 0 ]; then
                echo "  Running:"
                has_running=1
            fi
            local dir="${WS_DIR[$ws]:-?}"
            dir="${dir/#$HOME/\~}"
            printf "    %-22s %s\n" "$ws" "$dir"
        fi
    done
    [ "$has_running" -eq 1 ] && echo ""

    # Stopped
    local has_stopped=0
    for ws in "${WS_LIST[@]}"; do
        if [ "${WS_RUNNING[$ws]:-}" != "1" ]; then
            if [ "$has_stopped" -eq 0 ]; then
                echo "  Stopped:"
                has_stopped=1
            fi
            local dir="${WS_DIR[$ws]:-?}"
            dir="${dir/#$HOME/\~}"
            printf "    %-22s %s\n" "$ws" "$dir"
        fi
    done
    [ "$has_stopped" -eq 1 ] && echo ""
    return 0
}

# ─── Connect to Workspace ───

connect() {
    local ws="$1"
    local session="${2:-$ws}"
    local mode="${3:---attach}"  # --attach (default) or --new

    # Verify workspace exists
    if [ -z "${WS_UID[$ws]:-}" ]; then
        echo "  Error: unknown workspace '$ws'"
        echo "  Run 'claudes --list' to see available workspaces."
        exit 1
    fi

    # Start workspace if not running
    if [ "${WS_RUNNING[$ws]:-}" != "1" ]; then
        echo "  Workspace '$ws' is not running. Starting..."
        local ws_source="${WS_DIR[$ws]:-}"
        if [ -n "$ws_source" ]; then
            devpod up "$ws_source" --ide none
        else
            devpod up "$ws" --ide none
        fi
        echo ""
    fi

    # Inject Claude OAuth token into container (avoids re-auth on every rebuild)
    local token_file="$HOME/.claude/.setup-token"
    local token=""
    if [ -f "$token_file" ]; then
        token=$(head -1 "$token_file")
    fi

    echo "  Connecting to $ws (session: $session)..."
    # Pass token via env var — works in tmux, Docker, SSH without browser auth
    if [ -n "$token" ]; then
        exec ssh -t "${ws}.devpod" "export PATH=\$HOME/.local/bin:\$PATH CLAUDE_CODE_OAUTH_TOKEN=$token; claudes $mode ${session}"
    else
        exec ssh -t "${ws}.devpod" "export PATH=\$HOME/.local/bin:\$PATH; claudes $mode ${session}"
    fi
}

# ─── Auto-Rename Sessions ───

rename_sessions() {
    echo ""
    echo "  Analyzing sessions (in parallel)..."
    echo ""

    local tmpdir
    tmpdir=$(mktemp -d)
    local -a rename_queue=()
    local -a pids=()
    local -a labels=()
    local -a keys=()

    # Phase 1: Capture scrollback + launch LLM calls in parallel

    # Local sessions
    for s in "${LOCAL_SESSIONS[@]}"; do
        local content
        content=$(tmux capture-pane -t "$s" -p -S -500 2>/dev/null || true)
        if [ -z "$content" ]; then
            echo "  $s — (empty, skipping)"
            continue
        fi
        labels+=("$s")
        keys+=("local|$s")
        (echo "$content" | claude --print --model haiku "$RENAME_PROMPT" > "$tmpdir/${#keys[@]}" 2>/dev/null || true) &
        pids+=($!)
    done

    # DevPod sessions — capture scrollback in parallel first
    local -a devpod_capture_pids=()
    local -a devpod_entries=()
    for ws in "${WS_LIST[@]}"; do
        local sessions="${WS_SESSIONS[$ws]:-}"
        [ -n "$sessions" ] || continue
        IFS=',' read -ra sess_arr <<< "$sessions"
        for s in "${sess_arr[@]}"; do
            devpod_entries+=("$ws|$s")
            (ssh -o ConnectTimeout="$SSH_TIMEOUT" -o BatchMode=yes \
                "${ws}.devpod" \
                "tmux capture-pane -t '$s' -p -S -500 2>/dev/null || true" \
                > "$tmpdir/devpod-${ws}-${s}" 2>/dev/null || true) &
            devpod_capture_pids+=($!)
        done
    done

    # Wait for all DevPod captures, then launch their LLM calls
    for pid in "${devpod_capture_pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    for entry in "${devpod_entries[@]}"; do
        local ws="${entry%%|*}"
        local s="${entry#*|}"
        local capture_file="$tmpdir/devpod-${ws}-${s}"
        if [ ! -s "$capture_file" ]; then
            echo "  [$ws] $s — (empty, skipping)"
            continue
        fi
        labels+=("[$ws] $s")
        keys+=("devpod:$ws|$s")
        (claude --print --model haiku "$RENAME_PROMPT" < "$capture_file" > "$tmpdir/${#keys[@]}" 2>/dev/null || true) &
        pids+=($!)
    done

    # Wait for all LLM calls
    for pid in "${pids[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Collect results
    for i in "${!keys[@]}"; do
        local idx=$((i + 1))
        local raw=""
        [ -f "$tmpdir/$idx" ] && raw=$(cat "$tmpdir/$idx")
        local suggested
        suggested=$(sanitize_name "$raw")
        suggested="${suggested:-unknown}"
        echo "  ${labels[$i]} — $suggested"
        rename_queue+=("${keys[$i]}|$suggested")
    done

    rm -rf "$tmpdir"

    if [ ${#rename_queue[@]} -eq 0 ]; then
        echo ""
        echo "  No sessions to rename."
        echo ""
        echo "  Press Enter to return to menu..."
        read -r
        exec "$0"
    fi

    # Phase 2: Interactive confirmation
    echo ""
    echo "  ─────────────────────────────────────────"
    echo "  Confirm renames (Enter = accept, or type a new name, s = skip):"
    echo ""

    local renamed=0

    for entry in "${rename_queue[@]}"; do
        local entry_type="${entry%%|*}"
        local rest="${entry#*|}"
        local current="${rest%%|*}"
        local suggested="${rest#*|}"

        local label="$current"
        if [[ "$entry_type" == devpod:* ]]; then
            local ws="${entry_type#devpod:}"
            label="[$ws] $current"
        fi

        local user_input
        read -r -p "  $label → [$suggested]: " user_input

        if [ "$user_input" = "s" ] || [ "$user_input" = "S" ]; then
            echo "    (skipped)"
            continue
        fi

        local final_name="${user_input:-$suggested}"
        final_name=$(sanitize_name "$final_name")
        final_name="${final_name:-$suggested}"

        if [ "$final_name" = "$current" ]; then
            echo "    (unchanged)"
            continue
        fi

        if [ "$entry_type" = "local" ]; then
            local try_name="$final_name"
            local suffix=2
            while tmux has-session -t "$try_name" 2>/dev/null && [ "$try_name" != "$current" ]; do
                try_name="${final_name}-${suffix}"
                suffix=$((suffix + 1))
            done
            if tmux rename-session -t "$current" "$try_name" 2>/dev/null; then
                echo "    ✓ renamed to $try_name"
                renamed=$((renamed + 1))
            else
                echo "    ✗ failed"
            fi
        else
            local ws="${entry_type#devpod:}"
            local try_name="${ws}-${final_name}"
            local suffix=2
            # Reuse cached session list for collision detection
            local existing="${WS_SESSIONS[$ws]:-}"
            while echo ",$existing," | grep -q ",${try_name}," && [ "$try_name" != "$current" ]; do
                try_name="${ws}-${final_name}-${suffix}"
                suffix=$((suffix + 1))
            done
            if ssh -o ConnectTimeout="$SSH_TIMEOUT" -o BatchMode=yes \
                "${ws}.devpod" "tmux rename-session -t '$current' '$try_name'" 2>/dev/null; then
                echo "    ✓ renamed to $try_name"
                renamed=$((renamed + 1))
            else
                echo "    ✗ failed"
            fi
        fi
    done

    echo ""
    if [ "$renamed" -gt 0 ]; then
        echo "  Renamed $renamed session(s)."
    else
        echo "  No sessions renamed."
    fi
    echo ""
    echo "  Press Enter to return to menu..."
    read -r
    exec "$0"
}

# ─── Interactive Menu ───

interactive_menu() {
    echo ""
    echo "  claudes"
    echo "  ═══════"
    echo ""

    local detected_ws=""
    if detected_ws=$(detect_workspace_from_pwd); then
        echo "  (detected workspace: $detected_ws)"
        echo ""
    fi

    detect_local_sessions
    probe_remote_sessions

    local options=()      # display labels
    local actions=()      # "local:session", "connect:ws:session", or "start:ws"
    local idx=1

    # Local tmux sessions on WSL host
    if [ ${#LOCAL_SESSIONS[@]} -gt 0 ]; then
        echo "  Local sessions:"
        for s in "${LOCAL_SESSIONS[@]}"; do
            local dir="${LOCAL_SESSION_DIR[$s]:-}"
            dir="${dir/#$HOME/\~}"
            local att="${LOCAL_SESSION_ATT[$s]:-0}"
            local suffix=""
            if [ "$att" = "1" ]; then
                suffix="*"
            elif [ "$att" -gt 1 ] 2>/dev/null; then
                suffix="*${att}"
            fi
            # Show: idx) name  directory  attached-indicator
            printf "    %d) %-12s %-26s %s\n" "$idx" "$s" "$dir" "$suffix"
            options+=("$s")
            actions+=("local:$s")
            idx=$((idx + 1))
        done
        echo ""
    fi

    # Active sessions (across all running workspaces) with "+ new" per workspace
    local has_sessions=0
    for ws in "${WS_LIST[@]}"; do
        local sessions="${WS_SESSIONS[$ws]:-}"
        [ -n "$sessions" ] || continue
        if [ "$has_sessions" -eq 0 ]; then
            echo "  DevPod sessions:"
            has_sessions=1
        fi
        IFS=',' read -ra sess_arr <<< "$sessions"
        for s in "${sess_arr[@]}"; do
            printf "    %d) %-20s [%s]\n" "$idx" "$s" "$ws"
            options+=("$s")
            actions+=("attach:$ws:$s")
            idx=$((idx + 1))
        done
        # Add "+ new" entry for this workspace
        local next_name
        next_name=$(suggest_next_name "$ws" "$sessions")
        printf "    %d) %-20s [%s] → %s\n" "$idx" "+ new" "$ws" "$next_name"
        options+=("+ new $ws")
        actions+=("new:$ws:$next_name")
        idx=$((idx + 1))
    done
    [ "$has_sessions" -eq 1 ] && echo ""

    # Running workspaces without active sessions
    local has_available=0
    for ws in "${WS_LIST[@]}"; do
        [ "${WS_RUNNING[$ws]:-}" = "1" ] || continue
        [ -z "${WS_SESSIONS[$ws]:-}" ] || continue
        if [ "$has_available" -eq 0 ]; then
            echo "  Running (no sessions):"
            has_available=1
        fi
        printf "    %d) %s\n" "$idx" "$ws"
        options+=("$ws")
        actions+=("new:$ws:$ws")
        idx=$((idx + 1))
    done
    [ "$has_available" -eq 1 ] && echo ""

    # Stopped workspaces
    local has_stopped=0
    for ws in "${WS_LIST[@]}"; do
        [ "${WS_RUNNING[$ws]:-}" != "1" ] || continue
        if [ "$has_stopped" -eq 0 ]; then
            echo "  Stopped:"
            has_stopped=1
        fi
        printf "    %d) %s\n" "$idx" "$ws"
        options+=("$ws")
        actions+=("start:$ws")
        idx=$((idx + 1))
    done
    [ "$has_stopped" -eq 1 ] && echo ""

    local max=$((idx - 1))

    if [ "$max" -eq 0 ]; then
        echo "  No sessions or workspaces found."
        echo ""
    fi

    echo "    n) New local session"
    echo "    r) Rename all sessions (auto-detect what each is doing)"
    echo "    q) Quit"
    echo ""
    read -r -p "  Choose [1-${max}/n/r/q]: " choice

    case "$choice" in
        q|Q)
            exit 0
            ;;
        r|R)
            rename_sessions
            ;;
        n|N)
            local default_name
            default_name=$(basename "$PWD")
            read -r -p "  Session name [$default_name]: " session_name
            session_name="${session_name:-$default_name}"
            tmux_safe_open "$session_name" "$PWD"
            ;;
        [0-9]*)
            local chosen=$((choice - 1))
            if [ "$chosen" -ge 0 ] && [ "$chosen" -lt "$max" ]; then
                local action="${actions[$chosen]}"
                local act_type="${action%%:*}"
                local rest="${action#*:}"

                case "$act_type" in
                    local)
                        tmux_safe_open "$rest" "$PWD" --attach-only
                        ;;
                    start)
                        connect "$rest" "$rest" "--new"
                        ;;
                    attach)
                        local act_ws="${rest%%:*}"
                        local act_session="${rest#*:}"
                        connect "$act_ws" "$act_session" "--attach"
                        ;;
                    new)
                        local act_ws="${rest%%:*}"
                        local act_session="${rest#*:}"
                        connect "$act_ws" "$act_session" "--new"
                        ;;
                esac
            else
                echo "  Invalid choice."
                exit 1
            fi
            ;;
        *)
            echo "  Invalid choice."
            exit 1
            ;;
    esac
}

# ─── Legacy flag compat (claude-session -c WORKSPACE) ───

handle_legacy_flags() {
    case "${1:-}" in
        -c|--container)
            # claude-session -c WORKSPACE → claudes WORKSPACE
            if [ -n "${2:-}" ]; then
                connect "$2" "$2"
            else
                echo "Usage: claudes WORKSPACE"
                show_list
                exit 1
            fi
            ;;
        -d|--devpod)
            show_list
            exit 0
            ;;
        *)
            return 1  # not a legacy flag
            ;;
    esac
}

# ─── Main ───

main() {
    discover_workspaces
    detect_running

    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --list|-l)
            show_list
            exit 0
            ;;
        --local|-L)
            # Local tmux session in current directory (no DevPod/SSH)
            # Auto-name from directory basename if no name given
            local session="${2:-$(basename "$PWD")}"
            tmux_safe_open "$session" "$PWD"
            ;;
        "")
            # No args: always show menu (never auto-connect)
            interactive_menu
            ;;
        -*)
            # Try legacy flags first
            if ! handle_legacy_flags "$@"; then
                echo "  Unknown option: $1"
                show_help
                exit 1
            fi
            ;;
        *)
            local ws="$1"
            local label="${2:-}"

            # If arg isn't a known workspace, try auto-detect from PWD
            # e.g. "claudes frontend" in ~/git_wsl/rcom → rcom-frontend
            if [ -z "${WS_UID[$ws]:-}" ]; then
                local detected
                if detected=$(detect_workspace_from_pwd); then
                    # Treat the arg as a label for the auto-detected workspace
                    connect "$detected" "${detected}-${ws}"
                else
                    echo "  Error: unknown workspace '$ws'"
                    echo "  Run 'claudes --list' to see available workspaces."
                    exit 1
                fi
            elif [ -n "$label" ]; then
                connect "$ws" "${ws}-${label}"
            else
                connect "$ws" "$ws"
            fi
            ;;
    esac
}

main "$@"
