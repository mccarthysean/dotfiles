#!/usr/bin/env bash
# claudes — Manage persistent Claude Code tmux sessions (container-side)
#
# Usage:
#   claudes              # Interactive menu: list sessions or create new
#   claudes <name>       # Attach/create session in current directory
#   claudes --list       # List all Claude sessions
#   claudes --help       # Show this help
#
# New sessions auto-detect the workspace dir from devcontainer.json.
#
# Examples:
#   cd /project && claudes rcom     # session in project dir
#   claudes                         # Shows menu

set -euo pipefail

# ─── Ensure Claude Code is authenticated before entering tmux ───
# Pasting auth codes inside tmux (especially via SSH/Termius) is unreliable.
# Running auth outside tmux uses the raw terminal where paste works normally.
ensure_authenticated() {
    if ! command -v claude &>/dev/null; then
        echo "  Error: claude not found. Install with: curl -fsSL https://claude.ai/install.sh | bash"
        exit 1
    fi

    # Check if already authenticated (exit code 0 = authenticated)
    if claude auth status &>/dev/null; then
        return 0
    fi

    echo ""
    echo "  Claude Code needs authentication."
    echo "  Running auth now (outside tmux so paste works)..."
    echo ""
    claude auth login
    echo ""
}

# ─── Auto-detect workspace directory from devcontainer.json ───
# DevPod mounts the project into the container at the path specified by
# "workspaceFolder" in devcontainer.json. We search common mount parents
# for this file and extract the configured path. This ensures Claude Code
# starts in the project root where it can find CLAUDE.md, .claude/, etc.
detect_workdir() {
    local json
    # Search common DevPod/devcontainer mount points for devcontainer.json
    for parent in /workspaces /workspace /project; do
        # Check parent itself (e.g. /workspace/.devcontainer/devcontainer.json)
        if [ -f "$parent/.devcontainer/devcontainer.json" ]; then
            json="$parent/.devcontainer/devcontainer.json"
            break
        fi
        # Check one level down (e.g. /workspaces/wibble/.devcontainer/devcontainer.json)
        for sub in "$parent"/*/; do
            if [ -f "${sub}.devcontainer/devcontainer.json" ]; then
                json="${sub}.devcontainer/devcontainer.json"
                break 2
            fi
        done
    done

    if [ -n "${json:-}" ]; then
        # Extract workspaceFolder value from JSON (no jq dependency)
        local folder
        folder=$(grep -o '"workspaceFolder"[[:space:]]*:[[:space:]]*"[^"]*"' "$json" \
            | sed 's/.*"workspaceFolder"[[:space:]]*:[[:space:]]*"//;s/"$//')
        if [ -n "$folder" ] && [ -d "$folder" ]; then
            echo "$folder"
            return 0
        fi
    fi

    # Fallback: check for project markers in common locations
    for dir in /project /workspace /workspaces/*; do
        if [ -d "$dir" ] && { [ -f "$dir/CLAUDE.md" ] || [ -d "$dir/.claude" ] || [ -d "$dir/.git" ]; }; then
            echo "$dir"
            return 0
        fi
    done

    # Final fallback
    echo "$PWD"
}

validate_session_name() {
    local name="$1"
    if [[ "$name" =~ [.:] ]]; then
        echo "  Error: session name cannot contain dots or colons."
        exit 1
    fi
}

show_help() {
    sed -n '2,15s/^# //p' "$0"
}

list_sessions() {
    local names
    names=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    if [ -z "$names" ]; then
        echo "No active tmux sessions."
        return 1
    fi
    echo "Active sessions:"
    echo "──────────────────────────────────────"
    local i=1
    while IFS= read -r name; do
        local path timestamp age
        path=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null || echo "?")
        path="${path/#$HOME/\~}"
        timestamp=$(tmux display-message -t "$name" -p '#{session_activity}' 2>/dev/null || echo "0")
        age=$(date -d "@$timestamp" '+%H:%M' 2>/dev/null || echo "?")
        printf "  %d) %-20s %s (active %s)\n" "$i" "$name" "$path" "$age"
        i=$((i + 1))
    done <<< "$names"
    echo "──────────────────────────────────────"
    return 0
}

set_terminal_title() {
    printf '\033]0;%s\033\\' "$1"
}

attach_or_create() {
    local session="$1"
    local workdir="${2:-$(detect_workdir)}"

    validate_session_name "$session"
    set_terminal_title "$session"

    if [ -n "${TMUX:-}" ]; then
        if tmux has-session -t "$session" 2>/dev/null; then
            exec tmux switch-client -t "$session"
        else
            tmux new-session -d -s "$session" -c "$workdir" -e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}" -e "ANTHROPIC_API_KEY=" "claude; exec bash"
            exec tmux switch-client -t "$session"
        fi
    fi

    if tmux has-session -t "$session" 2>/dev/null; then
        # Check if session already has a client attached
        local attached
        attached=$(tmux display-message -t "$session" -p '#{session_attached}' 2>/dev/null || echo "0")
        if [ "$attached" -gt 0 ]; then
            # Session in use — find next available numbered name
            local orig_dir
            orig_dir=$(tmux display-message -t "$session" -p '#{pane_current_path}' 2>/dev/null || echo "$workdir")
            local n=2
            while tmux has-session -t "${session}-${n}" 2>/dev/null; do
                n=$((n + 1))
            done
            local new_session="${session}-${n}"
            echo "  Session '$session' already attached. Creating '$new_session'..."
            exec tmux new-session -s "$new_session" -c "$orig_dir" -e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}" -e "ANTHROPIC_API_KEY=" "claude; exec bash"
        else
            exec tmux attach-session -t "$session"
        fi
    else
        echo "Creating new session: $session ($workdir)"
        exec tmux new-session -s "$session" -c "$workdir" -e "CLAUDE_CODE_OAUTH_TOKEN=${CLAUDE_CODE_OAUTH_TOKEN:-}" -e "ANTHROPIC_API_KEY=" "claude; exec bash"
    fi
}

interactive_menu() {
    echo ""
    echo "  Claude Code Sessions"
    echo "  ════════════════════"
    echo ""

    # Collect existing sessions into an array (single tmux query)
    local sessions=()
    local count=0
    local raw
    raw=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    if [ -n "$raw" ]; then
        while IFS= read -r name; do
            sessions+=("$name")
            count=$((count + 1))
        done <<< "$raw"
    fi

    if [ "$count" -gt 0 ]; then
        echo "  Existing sessions:"
        local i=1
        for name in "${sessions[@]}"; do
            local path
            path=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null || echo "?")
            path="${path/#$HOME/\~}"
            printf "    %d) %s  (%s)\n" "$i" "$name" "$path"
            i=$((i + 1))
        done
        echo ""
    fi

    echo "    n) New session"
    echo "    q) Quit"
    echo ""

    read -r -p "  Choose [1-${count}/n/q]: " choice

    case "$choice" in
        q|Q)
            exit 0
            ;;
        n|N)
            echo ""
            read -r -p "  Session name: " session_name
            if [ -z "$session_name" ]; then
                echo "  No name given, aborting."
                exit 1
            fi
            attach_or_create "$session_name"
            ;;
        [0-9]*)
            local idx=$((choice - 1))
            if [ "$idx" -ge 0 ] && [ "$idx" -lt "$count" ]; then
                attach_or_create "${sessions[$idx]}"
            else
                echo "  Invalid choice."
                exit 1
            fi
            ;;
        *)
            # Treat any other input as a session name
            attach_or_create "$choice"
            ;;
    esac
}

# --- Main ---

case "${1:-}" in
    --help|-h)
        show_help
        exit 0
        ;;
    --list|-l)
        list_sessions
        exit 0
        ;;
    *)
        # Authenticate before entering tmux (paste works better outside tmux)
        ensure_authenticated

        if [ -z "${1:-}" ]; then
            interactive_menu
        else
            attach_or_create "$1" "${2:-}"
        fi
        ;;
esac
