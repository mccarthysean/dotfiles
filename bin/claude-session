#!/usr/bin/env bash
# claude-session — Manage persistent Claude Code tmux sessions
#
# Usage:
#   claude-session              # Interactive menu: list sessions or create new
#   claude-session <name>       # Attach/create session in current directory
#   claude-session --list       # List all Claude sessions
#   claude-session --ports      # Show DevPod SSH port allocation table
#   claude-session --help       # Show this help
#
# New sessions start in $PWD (cd to your project first, then run claude-session).
#
# Examples:
#   cd /project && claude-session rcom     # session in project dir
#   claude-session                         # Shows menu

set -euo pipefail

validate_session_name() {
    local name="$1"
    if [[ "$name" =~ [.:] ]]; then
        echo "  Error: session name cannot contain dots or colons."
        exit 1
    fi
}

show_help() {
    sed -n '2,16s/^# //p' "$0"
    echo ""
    show_ports
}

show_ports() {
    echo "DevPod SSH Ports (from host: claude-session -c PORT)"
    echo "──────────────────────────────────────────────────────"
    printf "  %-24s %s\n" "REPO" "PORT"
    echo "  ────────────────────── ────"
    printf "  %-24s %s\n" \
        "rcom" "2222" \
        "wibble" "2223" \
        "spartans-hockey" "2224" \
        "myijack-api" "2225" \
        "timescale_db" "2226" \
        "postgresql_scheduler" "2228" \
        "alerts" "2229" \
        "mqtt_jobs" "2230" \
        "mqtt_listener" "2231" \
        "traefik_ijack" "2232" \
        "monitoring" "2233"
    echo "──────────────────────────────────────────────────────"
}

list_sessions() {
    local names
    names=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    if [ -z "$names" ]; then
        echo "No active tmux sessions."
        return 1
    fi
    echo "Active sessions:"
    echo "──────────────────────────────────────"
    local i=1
    while IFS= read -r name; do
        local path timestamp age
        path=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null || echo "?")
        path="${path/#$HOME/\~}"
        timestamp=$(tmux display-message -t "$name" -p '#{session_activity}' 2>/dev/null || echo "0")
        age=$(date -d "@$timestamp" '+%H:%M' 2>/dev/null || echo "?")
        printf "  %d) %-20s %s (active %s)\n" "$i" "$name" "$path" "$age"
        i=$((i + 1))
    done <<< "$names"
    echo "──────────────────────────────────────"
    return 0
}

set_terminal_title() {
    printf '\033]0;%s\033\\' "$1"
}

attach_or_create() {
    local session="$1"
    local workdir="${2:-$PWD}"

    validate_session_name "$session"
    set_terminal_title "$session"

    if [ -n "${TMUX:-}" ]; then
        if tmux has-session -t "$session" 2>/dev/null; then
            exec tmux switch-client -t "$session"
        else
            tmux new-session -d -s "$session" -c "$workdir" "claude"
            exec tmux switch-client -t "$session"
        fi
    fi

    if tmux has-session -t "$session" 2>/dev/null; then
        exec tmux attach-session -t "$session"
    else
        echo "Creating new session: $session ($workdir)"
        exec tmux new-session -s "$session" -c "$workdir" "claude"
    fi
}

interactive_menu() {
    echo ""
    echo "  Claude Code Sessions"
    echo "  ════════════════════"
    echo ""

    # Collect existing sessions into an array (single tmux query)
    local sessions=()
    local count=0
    local raw
    raw=$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
    if [ -n "$raw" ]; then
        while IFS= read -r name; do
            sessions+=("$name")
            count=$((count + 1))
        done <<< "$raw"
    fi

    if [ "$count" -gt 0 ]; then
        echo "  Existing sessions:"
        local i=1
        for name in "${sessions[@]}"; do
            local path
            path=$(tmux display-message -t "$name" -p '#{pane_current_path}' 2>/dev/null || echo "?")
            path="${path/#$HOME/\~}"
            printf "    %d) %s  (%s)\n" "$i" "$name" "$path"
            i=$((i + 1))
        done
        echo ""
    fi

    echo "    n) New session"
    echo "    q) Quit"
    echo ""

    read -r -p "  Choose [1-${count}/n/q]: " choice

    case "$choice" in
        q|Q)
            exit 0
            ;;
        n|N)
            echo ""
            read -r -p "  Session name: " session_name
            if [ -z "$session_name" ]; then
                echo "  No name given, aborting."
                exit 1
            fi
            attach_or_create "$session_name"
            ;;
        [0-9]*)
            local idx=$((choice - 1))
            if [ "$idx" -ge 0 ] && [ "$idx" -lt "$count" ]; then
                attach_or_create "${sessions[$idx]}"
            else
                echo "  Invalid choice."
                exit 1
            fi
            ;;
        *)
            # Treat any other input as a session name
            attach_or_create "$choice"
            ;;
    esac
}

# --- Main ---

case "${1:-}" in
    --help|-h)
        show_help
        exit 0
        ;;
    --list|-l)
        list_sessions
        exit 0
        ;;
    --ports|-p)
        show_ports
        exit 0
        ;;
    "")
        interactive_menu
        ;;
    *)
        attach_or_create "$1" "${2:-}"
        ;;
esac
